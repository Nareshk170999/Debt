# Copy this file to ".env" and fill in your own values.
# Vite exposes anything prefixed with VITE_ to the app as import.meta.env.VITE_*

# Google Sheets / Drive spreadsheet link (native Sheets or uploaded .xlsx).
# Share the file as "Anyone with the link -> Viewer".
VITE_SHEET_URL="https://docs.google.com/spreadsheets/d/1I1itIjufqZUNzjqWEzkkwVaX3YLWUhCUojn9AgGF_r4/edit?usp=sharing"

# Optional: title shown in the dashboard header
VITE_DASHBOARD_TITLE="Data Dashboard"

# Auto-refresh interval in seconds (0 = off)
VITE_REFRESH_SECONDS="0"
